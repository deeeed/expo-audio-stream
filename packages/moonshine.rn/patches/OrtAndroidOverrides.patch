+val moonshineOrtLibPath = envOrProp("SITEED_MOONSHINE_ORT_LIB_PATH", "siteedMoonshineOrtLibPath")
+val moonshineOrtIncludeDir = envOrProp("SITEED_MOONSHINE_ORT_INCLUDE_DIR", "siteedMoonshineOrtIncludeDir")
