{
  "title": "Playground record screen smoke validation",
  "validate": {
    "workflow": {
      "entry": "nav-record",
      "pre_conditions": [
        "playground.agentic_ready"
      ],
      "nodes": {
        "nav-record": {
          "action": "navigate",
          "target": "/(tabs)/record",
          "next": "wait-record-route"
        },
        "wait-record-route": {
          "action": "wait_for",
          "route": "/record",
          "next": "wait-record-wrapper"
        },
        "wait-record-wrapper": {
          "action": "wait_for",
          "test_id": "record-screen-wrapper",
          "next": "wait-filename-input"
        },
        "wait-filename-input": {
          "action": "wait_for",
          "test_id": "filename-input",
          "next": "assert-recorder-idle"
        },
        "assert-recorder-idle": {
          "action": "eval_ref",
          "ref": "recording-state",
          "assert": {
            "operator": "eq",
            "field": "isRecording",
            "value": false
          }
          ,
          "next": "done"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
