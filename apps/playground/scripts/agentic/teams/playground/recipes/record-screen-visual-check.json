{
  "title": "Playground record screen visual validation",
  "description": "Uses setup and teardown hooks around a web screenshot baseline for the record screen.",
  "validate": {
    "workflow": {
      "setup": [
        {
          "id": "open-record-screen",
          "action": "flow_ref",
          "ref": "record-screen-smoke"
        }
      ],
      "entry": "capture-record-screen",
      "nodes": {
        "capture-record-screen": {
          "id": "capture-record-screen",
          "action": "screenshot",
          "baseline": "../baselines/record-screen-web.png",
          "max_diff_pixels": 0,
          "pixel_threshold": 18,
          "next": "done"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      },
      "teardown": [
        {
          "id": "assert-record-route",
          "action": "eval_ref",
          "ref": "route",
          "assert": {
            "operator": "eq",
            "field": "pathname",
            "value": "/record"
          }
        }
      ]
    }
  }
}
