{
  "title": "Playground recipe smoke validation",
  "description": "Composes the record-screen smoke flow and confirms the app remains on the record tab.",
  "validate": {
    "workflow": {
      "entry": "choose-platform",
      "nodes": {
        "choose-platform": {
          "action": "switch",
          "cases": [
            {
              "label": "ios",
              "when": {
                "operator": "eq",
                "field": "env.platform",
                "value": "ios"
              },
              "next": "record-screen-smoke-ios"
            },
            {
              "label": "android",
              "when": {
                "operator": "eq",
                "field": "env.platform",
                "value": "android"
              },
              "next": "record-screen-smoke-android"
            },
            {
              "label": "web",
              "when": {
                "operator": "eq",
                "field": "env.platform",
                "value": "web"
              },
              "next": "record-screen-smoke-web"
            }
          ],
          "default": "record-screen-smoke-web"
        },
        "record-screen-smoke-ios": {
          "action": "flow_ref",
          "ref": "record-screen-smoke",
          "next": "assert-route"
        },
        "record-screen-smoke-android": {
          "action": "flow_ref",
          "ref": "record-screen-smoke",
          "next": "assert-route"
        },
        "record-screen-smoke-web": {
          "action": "flow_ref",
          "ref": "record-screen-smoke",
          "next": "assert-route"
        },
        "assert-route": {
          "id": "assert-route",
          "action": "eval_ref",
          "ref": "route",
          "assert": {
            "operator": "eq",
            "field": "pathname",
            "value": "/record"
          },
          "next": "done"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
