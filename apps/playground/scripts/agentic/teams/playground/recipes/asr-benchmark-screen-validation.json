{
  "title": "Playground ASR benchmark validation",
  "description": "Loads the dev-only ASR benchmark screen and asserts the benchmark state is exposed to agentic automation.",
  "validate": {
    "workflow": {
      "entry": "benchmark-screen-smoke",
      "nodes": {
        "benchmark-screen-smoke": {
          "action": "call",
          "ref": "asr-benchmark-screen-ready",
          "next": "assert-route"
        },
        "assert-route": {
          "action": "eval_ref",
          "ref": "asr-benchmark-state",
          "assert": {
            "operator": "eq",
            "field": "route",
            "value": "/asr-benchmark"
          },
          "next": "assert-model-count"
        },
        "assert-model-count": {
          "action": "eval_ref",
          "ref": "asr-benchmark-state",
          "assert": {
            "operator": "gte",
            "field": "benchmarkModelCount",
            "value": 3
          },
          "next": "switch-to-simulated"
        },
        "switch-to-simulated": {
          "action": "press",
          "test_id": "asr-benchmark-mode-simulated",
          "next": "assert-simulated-mode"
        },
        "assert-simulated-mode": {
          "action": "eval_ref",
          "ref": "asr-benchmark-state",
          "assert": {
            "operator": "eq",
            "field": "mode",
            "value": "simulated"
          },
          "next": "wait-simulated-action"
        },
        "wait-simulated-action": {
          "action": "wait_for",
          "test_id": "asr-benchmark-run-simulated",
          "next": "done"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
