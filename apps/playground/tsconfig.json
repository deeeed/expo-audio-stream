{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "types": ["node", "jest"],
        "experimentalDecorators": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "paths": {
            "@siteed/expo-audio-studio": [
                "../../packages/audio-studio/src/index"
            ],
            "@siteed/expo-audio-studio/*": [
                "../../packages/audio-studio/src/*"
            ],
            "@siteed/react-native-essentia": [
                "../../packages/react-native-essentia/src/index"
            ],
            "@siteed/react-native-essentia/*": [
                "../../packages/react-native-essentia/src/*"
            ],
            "@siteed/audio-ui": ["../../packages/audio-ui/src/index"],
            "@siteed/audio-ui/*": ["../../packages/audio-ui/src/*"],
            "@siteed/agentic-dev": ["../../packages/agentic-dev/src/index"],
            "@siteed/agentic-dev/*": ["../../packages/agentic-dev/src/*"],
            "@siteed/moonshine.rn": ["../../packages/moonshine.rn/src/index"],
            "@siteed/moonshine.rn/*": ["../../packages/moonshine.rn/src/*"],
            "whisper.rn": ["./node_modules/whisper.rn/lib/typescript/index.d.ts"]
        },
        "module": "esnext"
    },
    "include": ["src", "app.config.ts"],
    "exclude": ["node_modules", "build", "node_modules/@storybook", ".rnstorybook"]
}
