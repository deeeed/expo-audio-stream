{
    "name": "@siteed/sherpa-voice",
    "version": "1.0.1",
    "main": "./src/main-sherpa-demo.ts",
    "scripts": {
        "eas-build-pre-install": "bash scripts/eas-build-pre-install.sh",
        "start": "NODE_ENV=development bash scripts/agentic/start-metro.sh && node scripts/agentic/start-interactive.mjs",
        "stop": "bash scripts/agentic/stop-metro.sh",
        "android": "RCT_METRO_PORT=7500 NODE_ENV=development expo run:android --port 7500",
        "ios": "APP_VARIANT=development RCT_METRO_PORT=7500 NODE_ENV=development expo run:ios --device \"${IOS_SIMULATOR:-SherpaVoice-Dev}\" --port 7500",
        "ios:boot": "../../scripts/ios-launch.sh --simulator \"${IOS_SIMULATOR:-SherpaVoice-Dev}\" --boot-only",
        "ios:launch": "../../scripts/ios-launch.sh --simulator \"${IOS_SIMULATOR:-SherpaVoice-Dev}\" --scheme sherpa-voice --port 7500",
        "ios:select": "../../scripts/ios-launch.sh --select --scheme sherpa-voice --port 7500",
        "android:launch": "../../scripts/android-launch.sh --scheme sherpa-voice --port 7500",
        "android:select": "../../scripts/android-launch.sh --select --scheme sherpa-voice --port 7500",
        "launch": "../../scripts/device-launch.sh --scheme sherpa-voice --port 7500",
        "open:android": "open -a \"Android Studio\" ./android",
        "open:ios": "open -a Xcode ios/SherpaVoiceDev.xcworkspace 2>/dev/null || open -a Xcode ios/SherpaVoice.xcworkspace",
        "devices": "WATCHER_PORT=7500 node scripts/agentic/cdp-bridge.mjs list-devices",
        "status": "WATCHER_PORT=7500 node scripts/agentic/cdp-bridge.mjs list-devices",
        "reload": "WATCHER_PORT=7500 bash scripts/agentic/device-cmd.sh reload",
        "typecheck": "tsc --noEmit",
        "web": "EXPO_USE_METRO_WORKSPACE_ROOT=1 NODE_ENV=development expo start --web --port 7500",
        "clean": "rimraf dist",
        "predeploy": "APP_VARIANT=production EXPO_WEB=true expo export -p web",
        "deploy": "yarn clean && NODE_ENV=production APP_VARIANT=production EXPO_WEB=true expo export -p web && cp apps/sherpa-voice/.deploy-gitattributes apps/sherpa-voice/dist/.gitattributes && gh-pages -t -d dist --dest sherpa-voice --repo https://github.com/deeeed/audiolab.git --dotfiles",
        "test": "jest --watchAll",
        "detox:build:ios": "detox build -c ios.sim.release",
        "detox:build:ios:debug": "detox build -c ios.sim.debug",
        "detox:build:android": "detox build -c android.att.release",
        "detox:build:android:debug": "detox build -c android.att.debug",
        "detox:build:android:emu": "detox build -c android.emu.release",
        "detox:build:android:emu:debug": "detox build -c android.emu.debug",
        "e2e:ios:screenshots": "detox test -c ios.sim.release e2e/screenshots.test.ts",
        "e2e:android:screenshots": "detox test -c android.att.release e2e/screenshots.test.ts",
        "e2e:android:emu:screenshots": "detox test -c android.emu.release e2e/screenshots.test.ts",
        "screenshot:development": "yarn setup:development && ./scripts/generate-screenshots.sh all env=development",
        "screenshot:production": "yarn setup:production && ./scripts/generate-screenshots.sh all env=production",
        "screenshot:android": "./scripts/generate-screenshots.sh android",
        "screenshot:android:production": "yarn setup:production && ./scripts/generate-screenshots.sh android env=production",
        "prepare:appstore": "yarn setup:production && ./scripts/setup-simulators.sh && ./scripts/generate-screenshots.sh ios env=production && echo 'App Store preparation complete! Screenshots are ready in fastlane/detox/ios.'",
        "prepare:appstore:force": "yarn setup:production:force && ./scripts/setup-simulators.sh && ./scripts/generate-screenshots.sh ios force env=production && echo 'App Store preparation complete with forced rebuild!'",
        "prepare:playstore": "yarn setup:production && ./scripts/setup-simulators.sh && ./scripts/generate-screenshots.sh android env=production && echo 'Play Store preparation complete! Screenshots are ready in fastlane/detox/android.'",
        "prepare:playstore:force": "yarn setup:production:force && ./scripts/setup-simulators.sh && ./scripts/generate-screenshots.sh android force env=production && echo 'Play Store preparation complete with forced rebuild!'",
        "prepare:stores": "yarn setup:production && ./scripts/setup-simulators.sh && yarn screenshot:production && echo 'All store screenshots ready!'",
        "lint": "expo lint",
        "setup:development": "bash scripts/setup-env.sh development",
        "setup:development:force": "bash scripts/setup-env.sh development force",
        "setup:production": "bash scripts/setup-env.sh production",
        "setup:production:force": "bash scripts/setup-env.sh production force",
        "setup:ios-simulator": "./scripts/setup-simulators.sh",
        "setup:android-emulator": "./scripts/setup-simulators.sh",
        "build:ios:development": "APP_VARIANT=development npx eas build --platform ios --profile development --local",
        "build:ios:production": "NODE_ENV=production APP_VARIANT=production npx eas build --platform ios --profile production",
        "build:ios:production:local": "NODE_ENV=production APP_VARIANT=production npx eas build --platform ios --profile production --local --no-wait",
        "build:android:development": "APP_VARIANT=development npx eas build --platform android --profile development --local",
        "build:android:production": "NODE_ENV=production APP_VARIANT=production npx eas build --platform android --profile production",
        "build:android:production:local": "NODE_ENV=production APP_VARIANT=production npx eas build --platform android --profile production --local --no-wait",
        "ota-update:production": "APP_VARIANT=production npx eas update --channel production",
        "ota-update:development": "APP_VARIANT=development npx eas update --channel development",
        "publish:store": "bash scripts/deploy-sherpa-voice.sh"
    },
    "jest": {
        "preset": "jest-expo"
    },
    "dependencies": {
        "@expo/vector-icons": "^15.0.3",
        "@gorhom/bottom-sheet": "^5.2.8",
        "@gorhom/portal": "^1.0.14",
        "@react-native-async-storage/async-storage": "2.2.0",
        "@react-native-community/slider": "5.1.2",
        "@react-navigation/bottom-tabs": "^7.2.0",
        "@react-navigation/native": "^7.0.14",
        "@react-navigation/native-stack": "^7.3.10",
        "@siteed/audio-studio": "workspace:^",
        "@siteed/design-system": "^0.51.3",
        "@siteed/react-native-logger": "^0.11.0",
        "@siteed/sherpa-onnx.rn": "workspace:^",
        "expo": "~55.0.5",
        "expo-asset": "55.0.7",
        "expo-audio": "~55.0.8",
        "expo-blur": "~55.0.8",
        "expo-build-properties": "~55.0.9",
        "expo-clipboard": "~55.0.8",
        "expo-constants": "~55.0.7",
        "expo-file-system": "~55.0.9",
        "expo-font": "~55.0.4",
        "expo-haptics": "~55.0.8",
        "expo-keep-awake": "~55.0.4",
        "expo-linking": "~55.0.7",
        "expo-localization": "~55.0.8",
        "expo-modules-core": "55.0.12",
        "expo-router": "~55.0.4",
        "expo-sharing": "~55.0.11",
        "expo-splash-screen": "~55.0.10",
        "expo-status-bar": "~55.0.4",
        "expo-symbols": "~55.0.5",
        "expo-system-ui": "~55.0.9",
        "expo-updates": "~55.0.11",
        "expo-web-browser": "~55.0.9",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-native": "0.83.2",
        "react-native-gesture-handler": "~2.30.0",
        "react-native-paper": "^5.15.0",
        "react-native-paper-dates": "^0.22.26",
        "react-native-reanimated": "4.2.1",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.23.0",
        "react-native-vector-icons": "^10.0.3",
        "react-native-web": "^0.21.0",
        "react-native-webview": "13.16.0",
        "react-native-worklets": "0.7.2"
    },
    "devDependencies": {
        "@babel/core": "^7.25.2",
        "@babel/plugin-proposal-decorators": "^7.25.9",
        "@config-plugins/detox": "^9.0.0",
        "@playwright/test": "^1.58.2",
        "@types/jest": "^29.5.12",
        "@types/react": "~19.2.10",
        "@types/react-test-renderer": "^18.3.0",
        "babel-plugin-module-resolver": "^5.0.2",
        "babel-plugin-transform-import-meta": "^2.3.2",
        "detox": "patch:detox@npm%3A20.47.0#~/.yarn/patches/detox-npm-20.47.0-75cd917eb6.patch",
        "dotenv-flow": "^4.1.0",
        "eslint": "^9.0.0",
        "eslint-config-expo": "~55.0.0",
        "expo-dev-client": "~55.0.11",
        "gh-pages": "^6.3.0",
        "jest": "^29.2.1",
        "jest-expo": "~55.0.0",
        "joi": "^17.13.3",
        "react-test-renderer": "18.3.1",
        "rimraf": "^6.0.1",
        "ts-jest": "^29.2.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    },
    "private": true
}