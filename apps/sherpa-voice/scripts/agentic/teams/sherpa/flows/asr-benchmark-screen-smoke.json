{
  "title": "Sherpa voice ASR benchmark screen smoke validation",
  "validate": {
    "workflow": {
      "entry": "nav-benchmark",
      "pre_conditions": [
        "sherpa.agentic_ready"
      ],
      "nodes": {
        "nav-benchmark": {
          "action": "navigate",
          "target": "/(tabs)/features/asr-benchmark",
          "next": "wait-sample-tab"
        },
        "wait-sample-tab": {
          "action": "wait_for",
          "test_id": "asr-benchmark-mode-sample",
          "next": "wait-live-tab"
        },
        "wait-live-tab": {
          "action": "wait_for",
          "test_id": "asr-benchmark-mode-live",
          "next": "assert-sample-state"
        },
        "assert-sample-state": {
          "action": "eval_ref",
          "ref": "asr-benchmark-ui",
          "assert": {
            "operator": "eq",
            "field": "route",
            "value": "/features/asr-benchmark"
          },
          "next": "switch-live-mode"
        },
        "switch-live-mode": {
          "action": "press",
          "test_id": "asr-benchmark-mode-live",
          "next": "wait-start-live"
        },
        "wait-start-live": {
          "action": "wait_for",
          "test_id": "asr-benchmark-start-live",
          "next": "wait-stop-live"
        },
        "wait-stop-live": {
          "action": "wait_for",
          "test_id": "asr-benchmark-stop-live",
          "next": "assert-live-state"
        },
        "assert-live-state": {
          "action": "eval_ref",
          "ref": "asr-benchmark-ui",
          "assert": {
            "operator": "eq",
            "field": "mode",
            "value": "live"
          },
          "next": "done"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
