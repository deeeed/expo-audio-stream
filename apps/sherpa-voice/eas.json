{
  "cli": {
    "version": ">= 14.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "channel": "development",
      "developmentClient": true,
      "env": {
        "APP_VARIANT": "development",
        "EAS_PROJECT_ID": "5360ada5-3236-4b98-8b54-4d680e9267c6",
        "NPM_AUTH_TOKEN": "NONE",
        "YARN_ENABLE_IMMUTABLE_INSTALLS": "false",
        "YARN_ENABLE_GLOBAL_CACHE": "false",
        "LANG": "en_US.UTF-8",
        "LC_ALL": "en_US.UTF-8"
      },
      "android": {
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "buildConfiguration": "Debug"
      },
      "cache": {
        "paths": [
          "~/.yarn/cache"
        ]
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "preview",
        "EAS_PROJECT_ID": "5360ada5-3236-4b98-8b54-4d680e9267c6",
        "NPM_AUTH_TOKEN": "NONE",
        "YARN_ENABLE_IMMUTABLE_INSTALLS": "false",
        "YARN_ENABLE_GLOBAL_CACHE": "false",
        "LANG": "en_US.UTF-8",
        "LC_ALL": "en_US.UTF-8"
      }
    },
    "production": {
      "channel": "production",
      "developmentClient": false,
      "env": {
        "APP_VARIANT": "production",
        "EAS_PROJECT_ID": "5360ada5-3236-4b98-8b54-4d680e9267c6",
        "NPM_AUTH_TOKEN": "NONE",
        "NODE_ENV": "production",
        "YARN_ENABLE_IMMUTABLE_INSTALLS": "false",
        "YARN_ENABLE_GLOBAL_CACHE": "false",
        "LANG": "en_US.UTF-8",
        "LC_ALL": "en_US.UTF-8"
      },
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "cache": {
        "disabled": false,
        "paths": [
          "node_modules"
        ]
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6760437954"
      },
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    },
    "open-testing": {
      "android": {
        "track": "beta",
        "releaseStatus": "draft"
      }
    }
  }
}
