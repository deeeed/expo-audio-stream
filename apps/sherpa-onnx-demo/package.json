{
  "name": "@siteed/sherpa-onnx-demo",
  "version": "1.0.0",
  "main": "./src/main-sherpa-demo.ts",
  "scripts": {
    "start": "NODE_ENV=development bash scripts/agentic/start-metro.sh && node scripts/agentic/start-interactive.mjs",
    "stop": "bash scripts/agentic/stop-metro.sh",
    "android": "RCT_METRO_PORT=7500 NODE_ENV=development expo run:android --port 7500",
    "ios": "RCT_METRO_PORT=7500 NODE_ENV=development expo run:ios --device --port 7500",
    "open:android": "open -a \"Android Studio\" ./android",
    "open:ios": "open -a Xcode ./ios",
    "devices": "WATCHER_PORT=7500 node scripts/agentic/cdp-bridge.mjs list-devices",
    "status": "WATCHER_PORT=7500 node scripts/agentic/cdp-bridge.mjs list-devices",
    "reload": "WATCHER_PORT=7500 bash scripts/agentic/device-cmd.sh reload",
    "typecheck": "tsc --noEmit",
    "web": "EXPO_USE_METRO_WORKSPACE_ROOT=1 NODE_ENV=development expo start --web --port 7500",
    "clean": "rimraf dist",
    "predeploy": "APP_VARIANT=production EXPO_WEB=true expo export -p web",
    "deploy": "yarn clean && NODE_ENV=production APP_VARIANT=production EXPO_WEB=true expo export -p web && gh-pages -t -d dist --dest sherpa-onnx-demo",
    "test": "jest --watchAll",
    "lint": "expo lint"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@gorhom/portal": "^1.0.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.1.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.3.10",
    "@siteed/design-system": "^0.51.3",
    "@siteed/expo-audio-studio": "workspace:^",
    "@siteed/react-native-logger": "^0.11.0",
    "@siteed/sherpa-onnx.rn": "workspace:^",
    "expo": "~55.0.5",
    "expo-asset": "55.0.7",
    "expo-audio": "~55.0.8",
    "expo-blur": "~55.0.8",
    "expo-build-properties": "~55.0.9",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.11",
    "expo-file-system": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-keep-awake": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-modules-core": "55.0.12",
    "expo-router": "~55.0.4",
    "expo-sharing": "~55.0.11",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-paper": "^5.15.0",
    "react-native-paper-dates": "^0.22.26",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^18.3.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-import-meta": "^2.3.2",
    "dotenv-flow": "^4.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "gh-pages": "^6.3.0",
    "jest": "^29.2.1",
    "jest-expo": "~55.0.0",
    "joi": "^17.13.3",
    "react-test-renderer": "18.3.1",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "private": true
}
